# GitHub token (used as default fallback)
GITHUB_TOKEN=

# Optional: per-account tokens if you want private contributions for each account.
# GitHub Actions Secret 名は GITHUB_ プレフィックス不可なので PORTFOLIO_TOKEN_* を推奨。
# PORTFOLIO_TOKEN_TYUKEI=...
# PORTFOLIO_TOKEN_CHUKEI2=...
PORTFOLIO_TOKEN_TYUKEI=
PORTFOLIO_TOKEN_CHUKEI2=
# backward compatibility:
GITHUB_TOKEN_TYUKEI=
GITHUB_TOKEN_CHUKEI2=

# Required for /api/events (Connpass v2)
CONNPASS_API_KEY=
